    .spacing-meta {
      flex: 1;
      min-width: 0;
    }

    .spacing-token-name {
      font-family: 'SF Mono', 'Fira Code', 'Consolas', monospace;
      font-size: 12px;
      font-weight: 600;
      color: var(--color-primary-default);
      background: var(--color-primary-light-90);
      padding: 2px 7px;
      border-radius: var(--radius-xs);
      display: inline-block;
      margin-bottom: 3px;
