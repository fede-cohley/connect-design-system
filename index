      text-align: center;
      color: var(--color-neutral-50);
      margin-top: 4px;
      font-family: 'SF Mono', 'Fira Code', 'Consolas', monospace;
    }

    .effect-input-wrap {
      flex: 1;
      min-width: 180px;
    }

    /* =========================================================
       LAYOUT GUIDE  —  Spacing & Grid
       ========================================================= */
    .spacing-scale {
      display: flex;
      flex-direction: column;
      gap: 12px;
      margin-bottom: 40px;
    }

    .spacing-row {
      display: flex;
      align-items: center;
      gap: 16px;
      background: var(--color-neutral-100);
      border-radius: var(--radius-sm);
      padding: 12px 16px;
      box-shadow: var(--shadow-sm);
    }

    .spacing-bar-wrap {
      width: 260px;
      flex-shrink: 0;
    }

    .spacing-bar {
      height: 28px;
      background: var(--color-primary-light-90);
      border-radius: var(--radius-xs);
      border-left: 3px solid var(--color-primary-default);
      position: relative;
