<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Connect — Design System</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

  <style>
    /* =========================================================
       CSS CUSTOM PROPERTIES  —  Design Tokens
       Source: ⚛️ Connect — Design System (Figma)
       Node: 8:2  /  Styles / Colors palette
       =========================================================

       USAGE
       ─────
       Reference any token in your CSS with var(--token-name).
       Example:
         .button-primary { background: var(--color-primary-default); }
    */

    :root {
      /* ── Brand ──────────────────────────────────────────── */
      --color-brand-logo: #FFFD38;

      /* ── Primary ────────────────────────────────────────── */
      --color-primary-default: #4A4EA2;
      --color-primary-light-10: #5C60AB;
      --color-primary-light-90: #EDEDF6;

      /* ── Feedback / Blue ────────────────────────────────── */
      --color-blue-dark-50:  #07377F;
      --color-blue-default:  #0D6EFD;
      --color-blue-light-10: #257DFD;
      --color-blue-light-90: #E7F1FF;

      /* ── Feedback / Green ───────────────────────────────── */
      --color-green-dark-50:  #0D442A;
      --color-green-default:  #198754;
      --color-green-light-10: #309365;
      --color-green-light-90: #E6F8EE;

      /* ── Feedback / Orange ──────────────────────────────── */
      --color-orange-dark-50:  #7F3F0A;
      --color-orange-default:  #FD7E14;
      --color-orange-light-10: #FD8B2C;
      --color-orange-light-90: #FFF2E8;

      /* ── Feedback / Red ─────────────────────────────────── */
      --color-red-dark-50:  #6E1B23;
      --color-red-default:  #DC3545;
      --color-red-light-10: #E04958;
      --color-red-light-90: #FFE6E6;

      /* ── Neutral ────────────────────────────────────────── */
      --color-neutral-00:  #212529;   /* Darkest  */
      --color-neutral-10:  #373B3F;
      --color-neutral-40:  #73767A;
      --color-neutral-50:  #8F9295;
      --color-neutral-80:  #D2D3D5;
      --color-neutral-90:  #E8E9EA;
      --color-neutral-95:  #F4F4F5;
      --color-neutral-100: #FFFFFF;   /* Lightest */

      /* ── Base / Accent ──────────────────────────────────── */
      --color-base-amber:    #FFD79D;
      --color-base-mint:     #AEE9D1;
      --color-base-sky:      #A4E8F2;
      --color-base-lilac:    #ECD4FF;
      --color-base-lemonade: #FAFFC5;

      /* ── Shadows ────────────────────────────────────────── */
      /* Shadow/SM — used on color swatches */
      --shadow-sm: 0px 1px 2px 0px rgba(0,0,0,0.30),
                   0px 1px 3px 1px rgba(0,0,0,0.15);

      /* ── Typography ─────────────────────────────────────── */
      --font-family: 'Inter', sans-serif;
      --font-weight-regular:   400;
      --font-weight-medium:    500;
      --font-weight-semibold:  600;
      --font-weight-bold:      700;

      /* ── Type Scale ─────────────────────────────────────── */
      --text-xs-size:   11px;   --text-xs-lh:   16px;
      --text-sm-size:   12px;   --text-sm-lh:   16px;
      --text-base-size: 14px;   --text-base-lh: 20px;
      --text-md-size:   16px;   --text-md-lh:   24px;
      --text-lg-size:   18px;   --text-lg-lh:   28px;
      --text-xl-size:   20px;   --text-xl-lh:   28px;
      --text-2xl-size:  24px;   --text-2xl-lh:  32px;
      --text-3xl-size:  28px;   --text-3xl-lh:  36px;
      --text-4xl-size:  32px;   --text-4xl-lh:  40px;

      /* ── Border Radius ──────────────────────────────────── */
      --radius-xs: 2px;
      --radius-sm: 4px;
      --radius-md: 8px;
      --radius-lg: 12px;
      --radius-xl: 16px;
      --radius-full: 9999px;

      /* ── Spacing (base scale) ───────────────────────────── */
      --space-1: 4px;
      --space-2: 8px;
      --space-3: 12px;
      --space-4: 16px;
      --space-5: 20px;
      --space-6: 24px;
      --space-8: 32px;
      --space-10: 40px;
      --space-12: 48px;

      /* ── Figma Named Spacing Tokens ─────────────────────── */
      --spacing-xs:  8px;
      --spacing-s:  16px;
      --spacing-m:  24px;
      --spacing-xm: 32px;
      --spacing-l:  48px;

      /* ── Semantic / Background ───────────────────────────── */
      --bg-primary-default:   #4A4EA2;
      --bg-primary-hover:     #3B3E82;
      --bg-primary-light:     #E9EAFA;
      --bg-success-default:   #198754;
      --bg-success-hover:     #146C43;
      --bg-success-light:     #E6F8EE;
      --bg-warning-default:   #FD7E14;
      --bg-warning-hover:     #CA6510;
      --bg-warning-light:     #FFF1E6;
      --bg-danger-default:    #DC3545;
      --bg-danger-hover:      #B02A37;
      --bg-danger-light:      #FFE6E6;
      --bg-info-default:      #0D6EFD;
      --bg-info-hover:        #0A58CA;
      --bg-info-light:        #E6EEFF;
      --bg-light-default:     #F4F4F5;
      --bg-light-hover:       #C7C9CA;
      --bg-dark-default:      #212529;
      --bg-dark-hover:        #4D5154;
      --bg-disabled:          #E8E9EA;
      --bg-container:         #FFFFFF;

      /* ── Semantic / Content ──────────────────────────────── */
      --content-primary:      #4A4EA2;
      --content-dark:         #212529;
      --content-default:      #373B3F;
      --content-secondary:    #797C80;
      --content-disabled:     #8F9295;
      --content-light:        #FFFFFF;
      --content-on-success:   #0B3D26;
      --content-on-danger:    #63181F;
      --content-on-warning:   #663000;
      --content-on-info:      #063272;
      --content-success:      #198754;
      --content-warning:      #FD7E14;

      /* ── Semantic / Border ───────────────────────────────── */
      --border-dark:          #212529;
      --border-disabled:      #8F9295;
      --border-default:       #D2D3D5;
      --border-light:         #FFFFFF;
      --border-success:       #198754;
      --border-danger:        #DC3545;
      --border-info:          #0D6EFD;
      --border-warning:       #FD7E14;
    }

    /* =========================================================
       BASE RESET & DOCUMENT
       ========================================================= */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html { scroll-behavior: smooth; }

    body {
      font-family: var(--font-family);
      font-size: var(--text-md-size);
      line-height: var(--text-md-lh);
      color: var(--color-neutral-00);
      background: var(--color-neutral-95);
    }

    /* =========================================================
       LAYOUT — SIDEBAR + MAIN
       ========================================================= */
    .layout {
      display: flex;
      min-height: 100vh;
    }

    /* ── Sidebar ──────────────────────────────────────────── */
    .sidebar {
      width: 240px;
      flex-shrink: 0;
      background: var(--color-neutral-100);
      border-right: 1px solid var(--color-neutral-90);
      padding: 32px 0;
      position: sticky;
      top: 0;
      height: 100vh;
      overflow-y: auto;
    }

    .sidebar-logo {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 0 24px 28px;
      border-bottom: 1px solid var(--color-neutral-90);
      margin-bottom: 24px;
    }

    .sidebar-logo-mark {
      width: 32px;
      height: 32px;
      background: var(--color-brand-logo);
      border-radius: var(--radius-sm);
      flex-shrink: 0;
    }

    .sidebar-logo-text {
      font-weight: var(--font-weight-semibold);
      font-size: var(--text-base-size);
      color: var(--color-neutral-00);
      line-height: 1.2;
    }

    .sidebar-logo-sub {
      font-size: var(--text-xs-size);
      color: var(--color-neutral-50);
      font-weight: var(--font-weight-regular);
    }

    .sidebar-section-label {
      font-size: var(--text-xs-size);
      font-weight: var(--font-weight-semibold);
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--color-neutral-50);
      padding: 16px 24px 6px;
    }

    .sidebar-nav { list-style: none; }

    .sidebar-nav a {
      display: block;
      padding: 7px 24px;
      font-size: var(--text-base-size);
      color: var(--color-neutral-10);
      text-decoration: none;
      transition: background 0.15s, color 0.15s;
      border-radius: 0;
    }

    .sidebar-nav a:hover {
      background: var(--color-primary-light-90);
      color: var(--color-primary-default);
    }

    .sidebar-nav a.active {
      background: var(--color-primary-light-90);
      color: var(--color-primary-default);
      font-weight: var(--font-weight-semibold);
      border-left: 3px solid var(--color-primary-default);
    }

    /* ── Main content ─────────────────────────────────────── */
    .main {
      flex: 1;
      padding: 48px 64px;
      max-width: 1200px;
      min-width: 0;
    }

    /* =========================================================
       PAGE HEADER
       ========================================================= */
    .page-header {
      margin-bottom: 56px;
    }

    .page-header-eyebrow {
      font-size: var(--text-sm-size);
      font-weight: var(--font-weight-semibold);
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--color-primary-default);
      margin-bottom: 8px;
    }

    .page-header h1 {
      font-size: var(--text-4xl-size);
      font-weight: var(--font-weight-bold);
      color: var(--color-neutral-00);
      line-height: var(--text-4xl-lh);
      letter-spacing: -0.5px;
      margin-bottom: 16px;
    }

    .page-header p {
      font-size: var(--text-md-size);
      color: var(--color-neutral-40);
      max-width: 640px;
      line-height: 26px;
    }

    .badge {
      display: inline-flex;
      align-items: center;
      padding: 4px 10px;
      border-radius: var(--radius-full);
      font-size: var(--text-xs-size);
      font-weight: var(--font-weight-semibold);
      background: var(--color-primary-light-90);
      color: var(--color-primary-default);
      margin-top: 16px;
    }

    /* =========================================================
       SECTION
       ========================================================= */
    .section {
      margin-bottom: 72px;
    }

    .section-header {
      display: flex;
      align-items: flex-end;
      gap: 12px;
      margin-bottom: 8px;
    }

    .section-header h2 {
      font-size: var(--text-2xl-size);
      font-weight: var(--font-weight-bold);
      color: var(--color-neutral-00);
      line-height: var(--text-2xl-lh);
      letter-spacing: -0.3px;
    }

    .section-count {
      font-size: var(--text-sm-size);
      color: var(--color-neutral-50);
      font-weight: var(--font-weight-regular);
      margin-bottom: 3px;
    }

    .section-desc {
      font-size: var(--text-base-size);
      color: var(--color-neutral-40);
      margin-bottom: 28px;
      line-height: 22px;
    }

    .section-divider {
      border: none;
      border-top: 1px solid var(--color-neutral-90);
      margin-bottom: 32px;
    }

    /* ── Subsection ────────────────────────────────────────── */
    .subsection {
      margin-bottom: 40px;
    }

    .subsection-title {
      font-size: var(--text-base-size);
      font-weight: var(--font-weight-semibold);
      color: var(--color-neutral-40);
      text-transform: uppercase;
      letter-spacing: 0.06em;
      margin-bottom: 16px;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .subsection-title::after {
      content: '';
      flex: 1;
      height: 1px;
      background: var(--color-neutral-90);
    }

    /* =========================================================
       COLOR SWATCHES
       ========================================================= */

    /*
     * .swatch-grid — responsive row of color cards
     * .swatch-card — individual card: swatch fill + metadata
     */
    .swatch-grid {
      display: flex;
      flex-wrap: wrap;
      gap: 16px;
    }

    .swatch-card {
      background: var(--color-neutral-100);
      border-radius: var(--radius-md);
      box-shadow: var(--shadow-sm);
      overflow: hidden;
      width: 160px;
      flex-shrink: 0;
      cursor: default;
      transition: transform 0.15s, box-shadow 0.15s;
    }

    .swatch-card:hover {
      transform: translateY(-2px);
      box-shadow: 0px 4px 8px 0px rgba(0,0,0,0.12),
                  0px 2px 4px 0px rgba(0,0,0,0.08);
    }

    .swatch-fill {
      height: 120px;
      width: 100%;
      position: relative;
    }

    /* Checkerboard pattern for transparent/white swatches */
    .swatch-fill.is-white {
      background-image:
        linear-gradient(45deg, #e0e0e0 25%, transparent 25%),
        linear-gradient(-45deg, #e0e0e0 25%, transparent 25%),
        linear-gradient(45deg, transparent 75%, #e0e0e0 75%),
        linear-gradient(-45deg, transparent 75%, #e0e0e0 75%);
      background-size: 12px 12px;
      background-position: 0 0, 0 6px, 6px -6px, -6px 0px;
    }

    .swatch-fill.is-white::after {
      content: '';
      position: absolute;
      inset: 0;
      background: #ffffff;
    }

    .swatch-meta {
      padding: 12px 14px;
    }

    .swatch-name {
      font-size: 13px;
      font-weight: var(--font-weight-semibold);
      color: var(--color-neutral-00);
      line-height: 18px;
      margin-bottom: 2px;
    }

    .swatch-hex {
      font-size: 12px;
      color: var(--color-neutral-50);
      font-family: 'SF Mono', 'Fira Code', 'Consolas', monospace;
    }

    .swatch-token {
      font-size: 10px;
      color: var(--color-neutral-80);
      font-family: 'SF Mono', 'Fira Code', 'Consolas', monospace;
      margin-top: 4px;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    /* Swatch role badge */
    .swatch-role {
      display: inline-block;
      font-size: 10px;
      font-weight: var(--font-weight-semibold);
      padding: 2px 6px;
      border-radius: var(--radius-xs);
      margin-top: 6px;
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }

    .swatch-role.role-default  { background: #FFFBE6; color: #996800; }
    .swatch-role.role-dark     { background: #FFF0F0; color: #8C1515; }
    .swatch-role.role-light    { background: #F0F7FF; color: #0052CC; }
    .swatch-role.role-lightest { background: #F0FFF4; color: #1A5C35; }

    /* =========================================================
       SINGLE LARGE SWATCH (Brand / Logo)
       ========================================================= */
    .swatch-hero {
      display: flex;
      align-items: stretch;
      gap: 0;
      border-radius: var(--radius-md);
      overflow: hidden;
      box-shadow: var(--shadow-sm);
      max-width: 480px;
    }

    .swatch-hero-fill {
      width: 220px;
      min-height: 140px;
      flex-shrink: 0;
    }

    .swatch-hero-meta {
      background: var(--color-neutral-100);
      padding: 20px 24px;
      display: flex;
      flex-direction: column;
      justify-content: center;
      flex: 1;
    }

    .swatch-hero-name {
      font-size: var(--text-xl-size);
      font-weight: var(--font-weight-semibold);
      color: var(--color-neutral-00);
      letter-spacing: -0.38px;
      line-height: 24px;
      margin-bottom: 6px;
    }

    .swatch-hero-hex {
      font-size: var(--text-md-size);
      color: var(--color-neutral-10);
      font-family: 'SF Mono', 'Fira Code', 'Consolas', monospace;
      margin-bottom: 10px;
    }

    .swatch-hero-desc {
      font-size: var(--text-sm-size);
      color: var(--color-neutral-50);
      line-height: 18px;
    }

    /* =========================================================
       CALLOUT / USAGE NOTE
       ========================================================= */
    .callout {
      display: flex;
      gap: 12px;
      padding: 14px 16px;
      border-radius: var(--radius-md);
      margin-bottom: 24px;
      font-size: var(--text-base-size);
      line-height: 20px;
    }

    .callout.callout-info {
      background: var(--color-blue-light-90);
      color: #0A3B7A;
      border-left: 3px solid var(--color-blue-default);
    }

    .callout.callout-warning {
      background: var(--color-orange-light-90);
      color: #6B3800;
      border-left: 3px solid var(--color-orange-default);
    }

    .callout-icon { font-size: 15px; flex-shrink: 0; margin-top: 1px; }

    /* =========================================================
       TYPOGRAPHY SECTION
       ========================================================= */
    .type-table {
      width: 100%;
      border-collapse: collapse;
      background: var(--color-neutral-100);
      border-radius: var(--radius-md);
      overflow: hidden;
      box-shadow: var(--shadow-sm);
      margin-bottom: 32px;
    }

    .type-table thead tr {
      background: var(--color-neutral-95);
    }

    .type-table th {
      padding: 12px 16px;
      text-align: left;
      font-size: var(--text-xs-size);
      font-weight: var(--font-weight-semibold);
      color: var(--color-neutral-50);
      text-transform: uppercase;
      letter-spacing: 0.08em;
      border-bottom: 1px solid var(--color-neutral-90);
    }

    .type-table td {
      padding: 14px 16px;
      font-size: var(--text-base-size);
      border-bottom: 1px solid var(--color-neutral-90);
      vertical-align: middle;
    }

    .type-table tr:last-child td { border-bottom: none; }

    .type-table .token-name {
      font-family: 'SF Mono', 'Fira Code', 'Consolas', monospace;
      font-size: 11px;
      background: var(--color-neutral-95);
      padding: 2px 6px;
      border-radius: var(--radius-xs);
      color: var(--color-primary-default);
    }

    .type-preview-row td:first-child {
      font-family: var(--font-family);
      color: var(--color-neutral-00);
    }

    /* =========================================================
       SHADOW SECTION
       ========================================================= */
    .shadow-grid {
      display: flex;
      flex-wrap: wrap;
      gap: 24px;
    }

    .shadow-card {
      background: var(--color-neutral-100);
      border-radius: var(--radius-md);
      padding: 32px 28px 24px;
      text-align: center;
      min-width: 200px;
      flex: 1;
    }

    .shadow-preview {
      width: 80px;
      height: 80px;
      background: var(--color-neutral-100);
      border-radius: var(--radius-md);
      margin: 0 auto 20px;
    }

    .shadow-card.shadow-sm .shadow-preview { box-shadow: var(--shadow-sm); }

    .shadow-card.shadow-md .shadow-preview {
      box-shadow: 0px 4px 8px 0px rgba(0,0,0,0.12),
                  0px 2px 4px 0px rgba(0,0,0,0.08);
    }

    .shadow-card.shadow-lg .shadow-preview {
      box-shadow: 0px 8px 16px 0px rgba(0,0,0,0.12),
                  0px 4px 8px 0px rgba(0,0,0,0.08);
    }

    .shadow-card.shadow-xl .shadow-preview {
      box-shadow: 0px 16px 32px 0px rgba(0,0,0,0.12),
                  0px 8px 16px 0px rgba(0,0,0,0.08);
    }

    .shadow-name {
      font-size: var(--text-base-size);
      font-weight: var(--font-weight-semibold);
      margin-bottom: 4px;
    }

    .shadow-value {
      font-size: 11px;
      font-family: 'SF Mono', 'Fira Code', 'Consolas', monospace;
      color: var(--color-neutral-50);
      line-height: 16px;
    }

    /* =========================================================
       BORDER RADIUS SECTION
       ========================================================= */
    .radius-grid {
      display: flex;
      flex-wrap: wrap;
      gap: 20px;
    }

    .radius-card {
      background: var(--color-neutral-100);
      border-radius: var(--radius-md);
      padding: 28px 20px 20px;
      min-width: 140px;
      text-align: center;
      box-shadow: var(--shadow-sm);
    }

    .radius-preview {
      width: 72px;
      height: 72px;
      background: var(--color-primary-light-90);
      border: 2px solid var(--color-primary-light-10);
      margin: 0 auto 16px;
    }

    .radius-name {
      font-size: var(--text-base-size);
      font-weight: var(--font-weight-semibold);
      margin-bottom: 2px;
    }

    .radius-value {
      font-size: 11px;
      font-family: 'SF Mono', 'Fira Code', 'Consolas', monospace;
      color: var(--color-neutral-50);
    }

    /* =========================================================
       COLOR APPLICATION SECTION
       ========================================================= */
    .usage-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
      gap: 16px;
      margin-bottom: 32px;
    }

    .usage-card {
      background: var(--color-neutral-100);
      border-radius: var(--radius-md);
      overflow: hidden;
      box-shadow: var(--shadow-sm);
    }

    .usage-card-header {
      padding: 16px 18px;
      font-weight: var(--font-weight-semibold);
      font-size: var(--text-base-size);
    }

    .usage-card-body {
      padding: 14px 18px;
      border-top: 1px solid var(--color-neutral-90);
    }

    .usage-row {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 10px;
    }

    .usage-row:last-child { margin-bottom: 0; }

    .usage-dot {
      width: 12px;
      height: 12px;
      border-radius: var(--radius-full);
      flex-shrink: 0;
    }

    .usage-label {
      font-size: var(--text-sm-size);
      color: var(--color-neutral-10);
      flex: 1;
    }

    .usage-hex {
      font-size: 11px;
      font-family: 'SF Mono', 'Fira Code', 'Consolas', monospace;
      color: var(--color-neutral-50);
    }

    /* =========================================================
       TOKENS REFERENCE TABLE
       ========================================================= */
    .tokens-table {
      width: 100%;
      border-collapse: collapse;
      font-size: var(--text-sm-size);
      background: var(--color-neutral-100);
      border-radius: var(--radius-md);
      overflow: hidden;
      box-shadow: var(--shadow-sm);
    }

    .tokens-table thead tr {
