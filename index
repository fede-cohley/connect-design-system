      height: 56px;
      border-radius: var(--radius-sm);
      border: 2px solid;
      background: var(--color-neutral-95);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 11px;
      color: var(--color-neutral-50);
      font-family: 'SF Mono', 'Fira Code', 'Consolas', monospace;
