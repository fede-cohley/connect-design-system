    .semantic-token-swatch {
      width: 20px;
      height: 20px;
      border-radius: var(--radius-xs);
      border: 1px solid rgba(0,0,0,0.08);
      flex-shrink: 0;
    }

    .semantic-token-name {
      font-family: 'SF Mono', 'Fira Code', 'Consolas', monospace;
      font-size: 11px;
      color: var(--color-primary-default);
