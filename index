      border-left: 1px dashed var(--color-orange-default);
    }

    .grid-content-zone {
      flex: 1;
      background: rgba(74, 78, 162, 0.08);
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 2px;
      padding: 8px 4px;
