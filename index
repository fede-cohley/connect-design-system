    .grid-col {
      flex: 1;
      height: 100%;
      background: rgba(74, 78, 162, 0.12);
      border-radius: 2px;
    }

    .grid-stats {
      display: flex;
      gap: 24px;
      margin-top: 14px;
      flex-wrap: wrap;
    }

    .grid-stat {
      display: flex;
      flex-direction: column;
      gap: 2px;
    }

    .grid-stat-label {
      font-size: var(--text-xs-size);
      color: var(--color-neutral-50);
      text-transform: uppercase;
      letter-spacing: 0.06em;
      font-weight: var(--font-weight-semibold);
    }

    .grid-stat-value {
      font-size: var(--text-base-size);
      font-weight: var(--font-weight-semibold);
      color: var(--color-neutral-00);
    }

    /* 8pt grid visual */
    .grid-8pt {
      display: flex;
      align-items: flex-end;
      gap: 8px;
      margin-bottom: 24px;
      flex-wrap: wrap;
    }

    .grid-8pt-block {
      background: var(--color-primary-default);
      border-radius: 2px;
      opacity: 0.15;
      transition: opacity 0.2s;
    }

    .grid-8pt-block:nth-child(1) { width: 8px;  height: 8px;  opacity: 0.30; }
    .grid-8pt-block:nth-child(2) { width: 16px; height: 16px; opacity: 0.40; }
    .grid-8pt-block:nth-child(3) { width: 24px; height: 24px; opacity: 0.50; }
    .grid-8pt-block:nth-child(4) { width: 32px; height: 32px; opacity: 0.60; }
    .grid-8pt-block:nth-child(5) { width: 48px; height: 48px; opacity: 0.70; }

    /* Semantic token table */
    .semantic-token-group {
      margin-bottom: 36px;
    }

    .semantic-group-title {
      font-size: var(--text-sm-size);
      font-weight: var(--font-weight-semibold);
      color: var(--color-neutral-40);
      text-transform: uppercase;
      letter-spacing: 0.06em;
      margin-bottom: 12px;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .semantic-group-title::after {
      content: '';
      flex: 1;
      height: 1px;
      background: var(--color-neutral-90);
    }

    .semantic-token-row {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 9px 14px;
      border-radius: var(--radius-sm);
      background: var(--color-neutral-100);
      margin-bottom: 4px;
      box-shadow: 0 1px 2px rgba(0,0,0,0.05);
